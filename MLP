        "#sample 8\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.feature_selection import SelectKBest, f_classif\n",
        "from sklearn.decomposition import PCA\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "# Set seed for reproducibility\n",
        "np.random.seed(42)\n",
        "\n",
        "# Generate Synthetic Data\n",
        "data = pd.DataFrame({\n",
        "    'StudyHours': np.random.normal(5, 2, 100),\n",
        "    'Attendance': np.random.normal(8, 2, 100),\n",
        "    'Participation': np.random.rand(100) * 10,\n",
        "    'ProjectScore': np.random.rand(100) * 100,\n",
        "    'TestScores': np.random.rand(100) * 100,\n",
        "    'Assignments': np.random.rand(100) * 100\n",
        "})\n",
        "\n",
        "# Create a target variable 'Pass' (1 if average of scores > 50, else 0)\n",
        "data['Pass'] = ((data['TestScores'] + data['Assignments'] + data['ProjectScore']) / 3 > 50).astype(int)\n",
        "\n",
        "print(\"Initial Data Head:\")\n",
        "print(data.head())\n",
        "\n",
        "# --- Scaling the Data ---\n",
        "# Feature selection/reduction works best when data is on the same scale\n",
        "scaler = StandardScaler()\n",
        "features_scaled = scaler.fit_transform(data.drop('Pass', axis=1))\n",
        "\n",
        "# --- 1. Feature Selection (SelectKBest) ---\n",
        "selector = SelectKBest(score_func=f_classif, k=3)\n",
        "selected_features = selector.fit_transform(features_scaled, data['Pass'])\n",
        "\n",
        "# Get the names of the selected features\n",
        "feature_names = data.columns[:-1] # All columns except 'Pass'\n",
        "selected_indices = selector.get_support()\n",
        "selected_feature_names = feature_names[selected_indices]\n",
        "\n",
        "print(f\"\\nSelected Features (K=3): {selected_feature_names.tolist()}\")\n",
        "\n",
        "# --- 2. Dimensionality Reduction (PCA) ---\n",
        "pca = PCA(n_components=2)\n",
        "features_pca = pca.fit_transform(features_scaled)\n",
        "\n",
        "# --- Final Comparison of Shapes ---\n",
        "print(\"\\n--- Data Reduction Summary ---\")\n",
        "print(\"Original Feature Shape:       \", data.drop('Pass', axis=1).shape)\n",
        "print(\"After Feature Selection Shape:\", selected_features.shape)\n",
        "print(\"After PCA (Reduction) Shape:  \", features_pca.shape)"
