        "#sample 4\n",
        "import os\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import StratifiedShuffleSplit\n",
        "\n",
        "# Path configuration (using double backslashes for Windows)\n",
        "data_path = \"/content/housing\"\n",
        "\n",
        "def load_housing_data(data_path):\n",
        "    csv_path = os.path.join(data_path, \"housing.csv\")\n",
        "    return pd.read_csv(csv_path)\n",
        "\n",
        "# Load data and preview\n",
        "housing = load_housing_data(data_path)\n",
        "print(housing.head())\n",
        "\n",
        "# Create income categories for stratification\n",
        "# pd.cut creates discrete 'bins' out of continuous data\n",
        "housing[\"income_cat\"] = pd.cut(\n",
        "    housing[\"median_income\"],\n",
        "    bins=[0, 1.5, 3.0, 4.5, 6, np.inf],\n",
        "    labels=[1, 2, 3, 4, 5]\n",
        ")\n",
        "\n",
        "print(housing[\"income_cat\"].value_counts())\n",
        "\n",
        "# Perform Stratified Splitting\n",
        "split = StratifiedShuffleSplit(n_splits=1, test_size=0.2, random_state=42)\n",
        "\n",
        "for train_index, test_index in split.split(housing, housing[\"income_cat\"]):\n",
        "    strat_train_set = housing.loc[train_index]\n",
        "    strat_test_set = housing.loc[test_index]\n",
        "\n",
        "# Remove 'income_cat' so the data returns to its original state\n",
        "for dataset in (strat_train_set, strat_test_set):\n",
        "    dataset.drop(\"income_cat\", axis=1, inplace=True)\n",
        "\n",
        "# Final Output Verification\n",
        "print(f\"Training set size: {len(strat_train_set)}\")\n",
        "print(f\"Test set size: {len(strat_test_set)}\")\n",
        "\n",
        "print(\"\\nStratified sampling Test set proportions:\")\n",
        "# Note: Since income_cat was dropped above, we check median_income distributions\n",
        "print(strat_test_set[\"median_income\"].value_counts() / len(strat_test_set))"
